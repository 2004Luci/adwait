# ===========================================
# Adwait Artha - Environment Variables Template
# ===========================================
# Copy this file to .env.local for local development (localhost:3000)
#
# Environments:
#   local     - .env.local, localhost:3000
#   staging   - staging branch deployments (.env.staging)
#   production - main branch deployments (.env.production)
#
# IMPORTANT: Never commit actual API keys to version control!
# ===========================================

# Environment identifier
APP_ENV=local

# Resend Email Service
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Arcjet Security (Rate Limiting & Bot Protection)
ARCJET_KEY=ajkey_xxxxxxxxxxxxxxxxxxxxxxxx
