# ===========================================
# Adwait Artha - Environment Variables Template
# ===========================================
# Copy this file to .env.local for local development
# Or to .env.development / .env.production for specific environments
#
# IMPORTANT: Never commit actual API keys to version control!
# ===========================================

# Environment identifier (development | production)
NEXT_PUBLIC_APP_ENV=development

# Resend Email Service
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Arcjet Security (Rate Limiting & Bot Protection)
# Get your API key from: https://app.arcjet.com
ARCJET_KEY=ajkey_xxxxxxxxxxxxxxxxxxxxxxxx
